# Relayer Environment Variables
# Chain A (Sepolia) configuration
SEPOLIA_RPC_URL=https://rpc.sepolia.org
SEPOLIA_VAULT_ADDRESS=0xYOUR_SEPOLIA_VAULT_ADDRESS
SEPOLIA_ROUTER_ADDRESS=0xYOUR_SEPOLIA_ROUTER_ADDRESS
SEPOLIA_ORIGIN_TOKEN_ADDRESS=0xYOUR_SEPOLIA_TOKEN_ADDRESS
SEPOLIA_START_BLOCK=0

# Chain B (Hoodi) configuration
HOODI_RPC_URL=https://rpc.hoodi.ethpandaops.io
HOODI_ROUTER_ADDRESS=0xYOUR_HOODI_ROUTER_ADDRESS
HOODI_WRAPPED_TOKEN_ADDRESS=0xYOUR_HOODI_WRAPPED_TOKEN_ADDRESS
HOODI_START_BLOCK=0

# Relayer key (must be the same address set as relayer in both routers)
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY

# Polling interval in milliseconds (default: 15000 = 15s)
POLL_INTERVAL_MS=15000

# Minimum confirmations before processing an event
MIN_CONFIRMATIONS=2
