# Frontend Environment Variables
VITE_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# Sepolia contract addresses
VITE_SEPOLIA_VAULT_ADDRESS=0xYOUR_SEPOLIA_VAULT_ADDRESS
VITE_SEPOLIA_ROUTER_ADDRESS=0xYOUR_SEPOLIA_ROUTER_ADDRESS
VITE_SEPOLIA_TOKEN_ADDRESS=0xYOUR_SEPOLIA_TOKEN_ADDRESS

# Hoodi contract addresses
VITE_HOODI_ROUTER_ADDRESS=0xYOUR_HOODI_ROUTER_ADDRESS
VITE_HOODI_WRAPPED_TOKEN_ADDRESS=0xYOUR_HOODI_WRAPPED_TOKEN_ADDRESS

# Optional custom RPC URLs (fallback to public RPCs if not set)
VITE_SEPOLIA_RPC_URL=https://rpc.sepolia.org
VITE_HOODI_RPC_URL=https://rpc.hoodi.ethpandaops.io
